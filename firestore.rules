rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/profiles/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.isAdmin == true;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --------------------------------------------------------------------------
    // PUBLIC READS (Required for Login Gatekeeper)
    // Users need to read these collections *before* they authenticate to verify
    // if their email is allowed to receive a magic link.
    // --------------------------------------------------------------------------
    
    match /profiles/{userId} {
      allow read: if true;
      // Allow write if:
      // 1. User is an admin
      // 2. User is the owner (UID match)
      // 3. User's authenticated email matches the profile email (allows merging duplicate accounts)
      allow write: if isAdmin() || (isSignedIn() && (
        request.auth.uid == userId || 
        request.auth.token.email.lower() == resource.data.email.lower() ||
        request.auth.token.email.lower() == request.resource.data.email.lower()
      ));
    }
    
    match /requests/{requestId} {
      allow read: if resource.data.accessMode == 'volunteer' || 
                    request.auth.token.email in resource.data.accessList || 
                    request.auth.uid == resource.data.ownerPub ||
                    isAdmin();
      allow write: if isSignedIn();
    }
    
    match /playlists/{playlistId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // --------------------------------------------------------------------------
    // AUTHENTICATED ONLY (Core App Data)
    // --------------------------------------------------------------------------

    match /submissions/{submissionId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /comments/{commentId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn(); 
      allow write: if isSignedIn();
    }
    
    match /extension_tokens/{tokenId} {
       allow read: if isSignedIn();
       allow write: if isSignedIn();
    }
    
    match /extension_codes/{codeId} {
       allow read: if isSignedIn();
       allow write: if isSignedIn();
    }

    match /invites/{inviteCode} {
       allow read: if true;
       allow write: if isSignedIn();
    }
    
    match /config/{docId} {
       allow read: if true; // Player needs this
       allow write: if isAdmin();
    }
    
    match /system/{docId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
    }
  }
}