# Firebase Configuration
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id

# Cloudflare R2 / S3 Compatible Storage Public Domain
VITE_R2_PUBLIC_DOMAIN=https://your-public-r2-domain.r2.dev

# Optional: Set this to a secret string for first-time admin signup
# Remove or leave empty after creating your initial admin account
VITE_ADMIN_SECRET=your_secret_admin_code

# Optional: Brand Theme & White-Label Customization
VITE_APP_MODE=MEW
# Overrides for white-label deployments (leave blank to use preset defaults):
# VITE_BRAND_NAME="Music Every Week"
# VITE_BRAND_SHORT_NAME="MEW"
# VITE_BRAND_LOGO_URL="/mewlogo.png"
# VITE_BRAND_SUPPORT_EMAIL="support@yourdomain.com"
# VITE_BRAND_TAGLINE="A collaborative music community and songwriting group."