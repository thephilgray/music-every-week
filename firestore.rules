rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --------------------------------------------------------------------------
    // PUBLIC READS (Required for Login Gatekeeper)
    // Users need to read these collections *before* they authenticate to verify
    // if their email is allowed to receive a magic link.
    // --------------------------------------------------------------------------
    
    match /profiles/{userId} {
      allow read: if true;
      // Only the user themselves or an admin can update their profile.
      allow write: if request.auth != null;
    }
    
    match /requests/{requestId} {
      allow read: if resource.data.accessMode == 'volunteer' || 
                    request.auth.token.email in resource.data.accessList || 
                    request.auth.uid == resource.data.ownerPub ||
                    (request.auth != null && exists(/databases/$(database)/documents/profiles/$(request.auth.uid)) && get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.isAdmin == true);
      allow write: if request.auth != null;
    }
    
    match /playlists/{playlistId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // --------------------------------------------------------------------------
    // AUTHENTICATED ONLY (Core App Data)
    // --------------------------------------------------------------------------

    match /submissions/{submissionId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /comments/{commentId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /notifications/{notificationId} {
      allow read: if request.auth != null; 
      allow write: if request.auth != null;
    }
    
    match /extension_tokens/{tokenId} {
       allow read: if request.auth != null;
       allow write: if request.auth != null;
    }
    
    match /extension_codes/{codeId} {
       allow read: if request.auth != null;
       allow write: if request.auth != null;
    }
    
    match /system/{docId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null;
    }
  }
}